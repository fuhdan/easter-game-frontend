# ==============================================================================
# FRONTEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to create environment-specific configurations:
#   cp frontend/.env.example frontend/.env.development
#   cp frontend/.env.example frontend/.env.test
#   cp frontend/.env.example frontend/.env.production
#
# Then customize for each environment.
#
# IMPORTANT: Never commit frontend/.env.development, frontend/.env.test, or frontend/.env.production!
# ==============================================================================

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# API Base URL
# - Docker (via nginx): /api/v1
# - Standalone dev (npm start): http://localhost:8000/v1
REACT_APP_API_BASE_URL=/api/v1

# ==============================================================================
# ENVIRONMENT SETTINGS
# ==============================================================================

# Environment
REACT_APP_ENVIRONMENT=development

# ==============================================================================
# ERROR TRACKING (Production Only)
# ==============================================================================

# Sentry DSN (OPTIONAL - get from https://sentry.io)
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Sentry Traces Sample Rate (0.0 to 1.0)
# REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0.1
