# ==============================================================================
# FRONTEND - BASE CONFIGURATION (No Secrets)
# ==============================================================================
# This file contains frontend base defaults with NO SECRETS.
# Safe to commit to version control.
#
# Frontend-specific settings go in:
#   - frontend/.env.development (gitignored)
#   - frontend/.env.test (gitignored)
#   - frontend/.env.production (gitignored)
#
# See frontend/.env.example for documentation.
# ==============================================================================

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# API Base URL (relative for production)
REACT_APP_API_BASE_URL=/api/v1

# ==============================================================================
# ENVIRONMENT SETTINGS
# ==============================================================================

# Environment
REACT_APP_ENVIRONMENT=development
